          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-29" parent="1" style="ellipse;whiteSpace=wrap;html=1;fontStyle=1" value="Memory data" vertex="1">
          <mxGeometry height="23" width="93" x="-1559.5" y="656" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-30" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontStyle=1;fontSize=15;" value="S" vertex="1">
          <mxGeometry height="19" width="26" x="-1665.5" y="692.5" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-31" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontStyle=1;fontSize=15;" value="S" vertex="1">
