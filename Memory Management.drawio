          <mxGeometry height="23" width="93" x="-1888.5" y="656" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-7" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontStyle=1;fontSize=15;" value="E" vertex="1">
          <mxGeometry height="19" width="26" x="-1994.5" y="691.5" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-11" edge="1" parent="1" style="html=1;rounded=0;endArrow=none;endFill=0;fontStyle=1" value="">
          <mxGeometry relative="1" width="100" as="geometry">
            <mxPoint x="-1838.5" y="679" as="sourcePoint" />
            <mxPoint x="-1838.5" y="766" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-13" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontStyle=1" value="Bus" vertex="1">
          <mxGeometry height="30" width="60" x="-1868.5" y="772" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-19" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=15;" value="CoreA 修改data过程：&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1.A会在总线上广播一个“我要修改这个地址”的信号（Request For Ownership / RFO）&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;2.&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;核心B 嗅探到这个信号，检查自己的缓存。如果发现自己也有这个地址的数据，它会将自己的状态设为 &lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-weight: bold;&quot;&gt;I(Invalid)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;3.&lt;/b&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;核心 A确认其他人都失效后，将自己的状态由 S 变为 &lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-weight: bold; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;M(Modified)&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt; 并进行写入。&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;ol type=&quot;1&quot; style=&quot;direction: ltr; unicode-bidi: embed; margin-top: 0in; margin-bottom: 0in; font-family: Calibri;&quot;&gt;&lt;br&gt;&lt;/ol&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="212" width="561" x="-2589" y="1338" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-20" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;div&gt;&lt;ul type=&quot;disc&quot; style=&quot;direction:ltr;unicode-bidi:embed;margin-top:0in;&lt;br/&gt; margin-bottom:0in&quot;&gt;&lt;br/&gt; &lt;li style=&quot;margin-top:0;margin-bottom:0;vertical-align:middle&quot;&gt;&lt;span style=&quot;font-weight:bold;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;工作流程：&lt;/span&gt;&lt;/li&gt;&lt;br/&gt;&lt;/ul&gt;&lt;/div&gt;&lt;ol type=&quot;1&quot; style=&quot;direction:ltr;unicode-bidi:embed;margin-top:0in;margin-bottom:&amp;lt;br/&amp;gt; 0in;font-family:Calibri;font-size:15.0pt;font-weight:normal;font-style:normal&quot;&gt;&lt;li value=&quot;1&quot; style=&quot;margin-top:0;margin-bottom:0;vertical-align:middle&quot;&gt;&lt;span style=&quot;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt;font-weight:normal;&amp;lt;br/&amp;gt;     font-style:normal;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;目录记录了每一个内存块当前被哪些核心持有。&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;margin-top:0;margin-bottom:0;vertical-align:middle&quot;&gt;&lt;span style=&quot;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;当核心 A想修改数据时，它向目录发送请求。&lt;/span&gt;&lt;/li&gt; &lt;li style=&quot;margin-top:0;margin-bottom:0;vertical-align:middle&quot;&gt;&lt;span style=&quot;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;目录查找记录，发现核心 B 和 C也有这份数据。&lt;/span&gt;&lt;/li&gt; &lt;li style=&quot;margin-top:0;margin-bottom:0;vertical-align:middle&quot;&gt;&lt;span style=&quot;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;目录只向 B 和 C发送“失效”消息（点对点通信）。&lt;/span&gt;&lt;/li&gt; &lt;li style=&quot;margin-top:0;margin-bottom:0;vertical-align:middle&quot;&gt;&lt;span style=&quot;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;B 和 C确认失效后回复目录，目录再授权 A 进行修改。&lt;/span&gt;&lt;/li&gt;&lt;br&gt;&lt;/ol&gt;" vertex="1">
          <mxGeometry height="211.75" width="533" x="-1564" y="171.25" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-21" parent="1" style="text;whiteSpace=wrap;html=1;fontColor=#FF0000;fontSize=20;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans&amp;quot;;&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;&lt;span style=&quot;mso-spacerun:yes&quot;&gt;&amp;nbsp;总线嗅探--&lt;/span&gt;一个实际的交互流程案例&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="35" width="371" x="-1997.5" y="586" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-24" edge="1" parent="1" source="qWZpPbq2GA6Z5xrev1HH-25" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;endArrow=none;endFill=0;fontStyle=1" target="qWZpPbq2GA6Z5xrev1HH-26">
