        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-26" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontStyle=1" value="CoreB" vertex="1">
          <mxGeometry height="27" width="96" x="-1482.5" y="688.5" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-27" edge="1" parent="1" source="qWZpPbq2GA6Z5xrev1HH-29" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontStyle=1" target="qWZpPbq2GA6Z5xrev1HH-25">
