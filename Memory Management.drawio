            <mxPoint x="-1181.5" y="1015.5" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-78" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontStyle=1" value="Bus" vertex="1">
          <mxGeometry height="30" width="60" x="-1211.5" y="1021.5" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-110" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=16;" value="CoreA 读取data，发出读请求，总线无人响应。从内存读取data，状态变为&lt;b&gt;E&lt;/b&gt;" vertex="1">
          <mxGeometry height="43" width="284" x="-1986.5" y="818" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-111" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=16;" value="CoreB 读取data，发出读请求，A嗅探到有人要共享。A 状态降级为&lt;b&gt;S&lt;/b&gt;，B读取到data，状态也为&lt;b&gt;S&lt;/b&gt;" vertex="1">
          <mxGeometry height="43" width="327" x="-1673" y="821" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-112" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=16;" value="CoreA 想要写入data，但是是S状态无法直接写。A在总线广播&quot;我要写(Invalidate)信号&quot;&lt;div&gt;B嗅探到，将自己的状态改I(Invalid)&lt;/div&gt;" vertex="1">
          <mxGeometry height="65" width="327" x="-1336.5" y="810" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-113" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=16;" value="CoreA 收到B的Invalid信号，将状态变为M(Modified)并写入新值" vertex="1">
          <mxGeometry height="65" width="283" x="-1989" y="1055.5" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-114" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=16;" value="CoreB读取数据data，发现是I(缓存未命中)，重新读取数据，发出读取请求" vertex="1">
          <mxGeometry height="65" width="283" x="-1660" y="1054.5" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-115" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=16;" value="CoreA嗅探到读请求，发现自己是M状态，必须先暂停A的读取，先把内存写回内存或直接传给B。&lt;div&gt;A降级为S，B拿到数据也为S&lt;/div&gt;" vertex="1">
          <mxGeometry height="87" width="283" x="-1327" y="1054.5" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-116" parent="1" style="text;whiteSpace=wrap;html=1;fontColor=#0000FF;fontSize=30;verticalAlign=middle;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans&amp;quot;;&quot;&gt;&lt;b&gt;内存屏障和C/C++ 中的volatile&lt;/b&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="51" width="444.5" x="-978" y="665.5" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-117" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=20;fontColor=#FF0000;fontStyle=1" value="内存屏障见左图示" vertex="1">
          <mxGeometry height="30" width="163.5" x="-975.5" y="708" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-118" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=20;fontColor=#FF0000;fontStyle=1" value="C/C++中的volatile" vertex="1">
          <mxGeometry height="30" width="181" x="-975.5" y="1265" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-119" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=19;" value="1.告诉编译器“这个变量可能会被未知的外部因素（如硬件中断、I/O端口）修改”。" vertex="1">
          <mxGeometry height="30" width="746" x="-934" y="1300.5" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-120" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;2.禁止&lt;span style=&quot;font-weight:bold&quot;&gt;编译器&lt;/span&gt;对该变量进行优化（比如不要把它缓存在寄存器里，每次都要去内存读）。&lt;/p&gt;" vertex="1">
          <mxGeometry height="46" width="804" x="-934" y="1323.5" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-121" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;3.不能&lt;/span&gt;阻止 CPU 硬件层面的指令重排序！&lt;/p&gt;" vertex="1">
          <mxGeometry height="33" width="375" x="-934" y="1358.5" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-122" parent="1" style="text;whiteSpace=wrap;html=1;fontColor=#0000FF;fontSize=30;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans&amp;quot;;&quot;&gt;&lt;b&gt;Lock-Free (无锁编程) CAS (Compare-And-Swap)&lt;/b&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="51" width="715" x="-988" y="13.5" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-124" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;之所以叫“无锁”，不是因为它真的没有限制，而是因为它&lt;span style=&quot;font-weight:bold&quot;&gt;不用操作系统层面的“互斥锁” (Mutex)&lt;/span&gt;。&lt;/p&gt;&lt;br&gt;&lt;br&gt;&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;在传统的Mutex 模式下，如果一个线程拿不到锁，操作系统会让它“睡觉”（挂起，Context Switch），把 CPU 让给别人。这个过程虽然公平，但&lt;span style=&quot;font-weight:bold&quot;&gt;切换成本极高&lt;/span&gt;（保存寄存器、刷新缓存等）。&lt;/p&gt;&lt;br&gt;&lt;br&gt;&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;Lock-Free 的核心哲学是：&lt;/span&gt;不要让线程睡觉，而是让它在用户态“不断尝试”，直到成功为止。这依赖于一条神级硬件指令：&lt;span style=&quot;font-weight:bold&quot;&gt;CAS(Compare-And-Swap)&lt;/span&gt;。&lt;/p&gt;" vertex="1">
          <mxGeometry height="187.5" width="974" x="-992" y="64.5" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-125" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans&amp;quot;;font-size:16.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;什么是 CAS (Compare-And-Swap)？&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="29.13" width="364" x="-994.34" y="253.5" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-126" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans&amp;quot;;font-size:16.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;如何用 CAS 实现无锁？（CAS Loop）&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="22.87" width="359" x="-994.34" y="320" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-127" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans&amp;quot;;font-size:16.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;无锁编程的经典陷阱：ABA 问题&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="19.75" width="318" x="-992" y="404" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-128" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=20;fontColor=#FF0000;fontStyle=1" value="手动控制内存屏障的强度" vertex="1">
          <mxGeometry height="30" width="223.5" x="-975.5" y="739.5" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-129" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;这意味着它是&lt;span style=&quot;font-weight:bold&quot;&gt;原子性&lt;/span&gt;的：要么全做，要么全不做，中间不会被打断。&lt;/p&gt;" vertex="1">
          <mxGeometry height="28.25" width="662" x="-950" y="283.75" as="geometry" />
        </mxCell>
        <mxCell id="jdp7ciYfCAcHsXH9sEiK-1" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;C++std::atomic 中的 &lt;span style=&quot;font-weight:bold&quot;&gt;Memory Order (relaxed, acquire,release)&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="40.5" width="595" x="-950" y="766.5" as="geometry" />
        </mxCell>
        <mxCell id="jdp7ciYfCAcHsXH9sEiK-2" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;" value="&lt;p style=&quot;margin:0in;font-size:16.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold;font-family:&amp;quot;Google Sans&amp;quot;&quot;&gt;1.绝对安全，但也最慢：顺序一致性 (&lt;/span&gt;&lt;span style=&quot;font-weight:bold;font-family:&amp;quot;Google Sans Text&amp;quot;&quot;&gt;memory_order_seq_cst&lt;/span&gt;&lt;span style=&quot;font-weight:bold;font-family:&amp;quot;Google Sans&amp;quot;&quot;&gt;)&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="31" width="627" x="-923" y="800" as="geometry" />
        </mxCell>
        <mxCell id="jdp7ciYfCAcHsXH9sEiK-3" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;" value="&lt;p style=&quot;margin:0in;font-size:16.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold;font-family:&amp;quot;Google Sans&amp;quot;&quot;&gt;2.彻底狂野：松散模型 (&lt;/span&gt;&lt;span style=&quot;font-weight:bold;font-family:&amp;quot;Google Sans Text&amp;quot;&quot;&gt;memory_order_relaxed&lt;/span&gt;&lt;span style=&quot;font-weight:bold;font-family:&amp;quot;Google Sans&amp;quot;&quot;&gt;)&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="29" width="486.71" x="-923" y="902.5" as="geometry" />
        </mxCell>
        <mxCell id="jdp7ciYfCAcHsXH9sEiK-4" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans&amp;quot;;font-size:16.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;3.高手的武器库：获取-释放语义 (Acquire-Release)&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="36.06" width="500.71" x="-923" y="1044" as="geometry" />
        </mxCell>
        <UserObject label="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;比如直接写std::atomic_int.store(1);&lt;/p&gt;" id="jdp7ciYfCAcHsXH9sEiK-5">
          <mxCell parent="1" style="text;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="40" width="421" x="-904" y="829.5" as="geometry" />
          </mxCell>
        </UserObject>
        <mxCell id="jdp7ciYfCAcHsXH9sEiK-6" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;fontSize=18;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;编译器会在底层插入最重的内存屏障（&lt;b&gt;Full Memory Barrier&lt;/b&gt;），&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;强行清空我们在上个话题提到的 Store Buffer&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="31" width="867" x="-904" y="863" as="geometry" />
        </mxCell>
        <mxCell id="jdp7ciYfCAcHsXH9sEiK-7" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;只保证&lt;/span&gt;对这个原子变量本身的读写是完整的&lt;/p&gt;" vertex="1">
          <mxGeometry height="25.5" width="384" x="-904" y="931.5" as="geometry" />
        </mxCell>
        <mxCell id="jdp7ciYfCAcHsXH9sEiK-8" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;完全不保证&lt;/span&gt;它前后的其他指令的执行顺序！编译器和 CPU 可以随意将前后的代码重排&lt;/p&gt;" vertex="1">
          <mxGeometry height="30" width="760" x="-904" y="960" as="geometry" />
        </mxCell>
        <mxCell id="jdp7ciYfCAcHsXH9sEiK-9" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;比如，一个纯粹的&lt;span style=&quot;font-weight:bold&quot;&gt;性能计数器&lt;/span&gt;（比如统计渲染引擎每秒绘制了多少个多边形），你只需要&#xa;counter.fetch_add(1, std::memory_order_relaxed)&lt;/p&gt;" vertex="1">
          <mxGeometry height="42.5" width="779" x="-904" y="996" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="R3RajqSZWAp9AMWC7a3E" name="内存分配与回收">
    <mxGraphModel dx="3211" dy="1254" grid="0" gridSize="10" guides="1" tooltips="1" connect="0" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="1600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="G8sECt7ZoDkIn5LzIyny-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=30;fontColor=#0000FF;fontStyle=1" value="内存池" vertex="1">
          <mxGeometry height="33" width="92" x="2002" y="3" as="geometry" />
        </mxCell>
        <mxCell id="G8sECt7ZoDkIn5LzIyny-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=20;fontColor=#FF0000;fontStyle=1" value="最佳场景" vertex="1">
          <mxGeometry height="30" width="90" x="2002" y="98" as="geometry" />
        </mxCell>
        <mxCell id="G8sECt7ZoDkIn5LzIyny-3" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=16;verticalAlign=middle;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Microsoft YaHei&amp;quot;;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;目的是减少动态内存分配的开销，避免频繁的系统调用，特别是在频繁创建销毁相似对象的场景中效果显著。&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Microsoft YaHei&amp;quot;;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;考虑那些对性能要求极高、对象生命周期局限明确、且内存使用有特殊优化需求的场景，例如游戏中的实体对象池。&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Microsoft YaHei&amp;quot;;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;应注意不同对象的对齐要求和内存碎片问题，以及池的预先分配策略&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="57" width="822" x="2037" y="39" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-1" edge="1" parent="1" source="G8sECt7ZoDkIn5LzIyny-1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;verticalAlign=middle;" target="G8sECt7ZoDkIn5LzIyny-1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-4" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;" value="&lt;span style=&quot;color: rgb(0, 0, 0); font-family: &amp;quot;Microsoft YaHei&amp;quot;; font-size: 16px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; float: none; display: inline !important;&quot;&gt;自定义内存池适合在&lt;/span&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-family: &amp;quot;Microsoft YaHei&amp;quot;; font-size: 16px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; float: none; display: inline !important;&quot;&gt;&lt;b&gt;高频率分配&lt;/b&gt;&lt;/span&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-family: &amp;quot;Microsoft YaHei&amp;quot;; font-size: 16px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; float: none; display: inline !important;&quot;&gt;和&lt;/span&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-family: &amp;quot;Microsoft YaHei&amp;quot;; font-size: 16px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; float: none; display: inline !important;&quot;&gt;&lt;b&gt;回收同一类型对象&lt;/b&gt;&lt;/span&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-family: &amp;quot;Microsoft YaHei&amp;quot;; font-size: 16px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; float: none; display: inline !important;&quot;&gt;，&lt;/span&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-family: &amp;quot;Microsoft YaHei&amp;quot;; font-size: 16px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; float: none; display: inline !important;&quot;&gt;&lt;b&gt;减少碎片&lt;/b&gt;&lt;/span&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-family: &amp;quot;Microsoft YaHei&amp;quot;; font-size: 16px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; float: none; display: inline !important;&quot;&gt;和&lt;/span&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-family: &amp;quot;Microsoft YaHei&amp;quot;; font-size: 16px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; float: none; display: inline !important;&quot;&gt;&lt;b&gt;提升性能&lt;/b&gt;&lt;/span&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-family: &amp;quot;Microsoft YaHei&amp;quot;; font-size: 16px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; float: none; display: inline !important;&quot;&gt;的场景，如游戏中的&lt;/span&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-family: &amp;quot;Microsoft YaHei&amp;quot;; font-size: 16px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; float: none; display: inline !important;&quot;&gt;&lt;b&gt;实体&lt;/b&gt;&lt;/span&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-family: &amp;quot;Microsoft YaHei&amp;quot;; font-size: 16px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; float: none; display: inline !important;&quot;&gt;、&lt;/span&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-family: &amp;quot;Microsoft YaHei&amp;quot;; font-size: 16px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; float: none; display: inline !important;&quot;&gt;&lt;b&gt;组件管理&lt;/b&gt;&lt;/span&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-family: &amp;quot;Microsoft YaHei&amp;quot;; font-size: 16px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; float: none; display: inline !important;&quot;&gt;等，尤其在时间敏感性较高的实时系统中效果明显。&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-family: &amp;quot;Microsoft YaHei&amp;quot;; font-size: 16px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; float: none; display: inline !important;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-family: &amp;quot;Microsoft YaHei&amp;quot;; font-size: 16px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; float: none; display: inline !important;&quot;&gt;通常是那些&lt;span style=&quot;font-weight:bold&quot;&gt;标准内存分配器成为性能瓶颈&lt;/span&gt;的情况。以下是几个最经典的适用场景：&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="91" width="884" x="2036" y="125" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-5" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=16;verticalAlign=middle;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans&amp;quot;;&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;1.频繁创建和销毁大量&lt;u&gt;小对象&lt;/u&gt;&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="32" width="228" x="2036" y="221" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-6" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=15;verticalAlign=middle;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;b&gt;痛点&lt;/b&gt;：标准分配器在处理小对象时，除了对象本身的内存，还会额外分配用于记录内存块大小等信息的控制头（Overhead）。此外，频繁的碎片化释放会导致严重的&lt;u&gt;内存碎片（Memory Fragmentation）&lt;/u&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="54" width="840" x="2072" y="250" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-7" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=15;verticalAlign=middle;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;b&gt;举例&lt;/b&gt;：戏引擎中的粒子系统、同屏海量的弹幕/子弹、网络服务器接收和发送的短连接数据包（如TCP 流的 Buffer 解析）。&lt;/p&gt;" vertex="1">
          <mxGeometry height="30" width="823" x="2072" y="296" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-8" parent="1" style="shape=curlyBracket;whiteSpace=wrap;html=1;rounded=1;labelPosition=left;verticalLabelPosition=middle;align=right;verticalAlign=middle;" value="" vertex="1">
          <mxGeometry height="49" width="20" x="2052" y="263" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-9" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=16;verticalAlign=middle;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans&amp;quot;;&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;2.对实时性（Latency）有极高要求的系统&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="30.81" width="321" x="2036" y="318" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-10" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=15;verticalAlign=middle;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;b&gt;痛点&lt;/b&gt;：标准库的内存分配时间是不确定的。如果当前堆中没有合适的空间，malloc可能会触发系统调用（如 brk 或 mmap）去向操作系统要内存，这会导致不可预测的延迟峰值（Spike）&lt;/p&gt;" vertex="1">
          <mxGeometry height="44" width="830" x="2072" y="343" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-11" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=15;verticalAlign=middle;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;b&gt;举例&lt;/b&gt;：&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-family: Helvetica;&quot;&gt;3A游戏引擎的渲染主循环、物理引擎模拟、高频量化交易系统、实时音视频处理。内存池的分配（特别是定长内存池）通常只需移动一下指针，时间复杂度是极其稳定的 &lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-family: Helvetica; font-weight: bold;&quot;&gt;O(1)&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-family: Helvetica;&quot;&gt;。&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="30" width="823" x="2072" y="389" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-12" parent="1" style="shape=curlyBracket;whiteSpace=wrap;html=1;rounded=1;labelPosition=left;verticalLabelPosition=middle;align=right;verticalAlign=middle;" value="" vertex="1">
          <mxGeometry height="62.83" width="20" x="2052" y="355.17" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-13" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=16;verticalAlign=middle;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans&amp;quot;;&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;3.高并发的多线程环境&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="30.81" width="172" x="2036" y="434" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-14" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=15;verticalAlign=middle;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;b&gt;痛点&lt;/b&gt;：在多线程程序中，系统的全局堆是共享资源。当多个线程同时调用new 或 malloc 时，底层分配器必须加锁以保证线程安全，这会引发严重的锁竞争（Lock Contention）&lt;/p&gt;" vertex="1">
          <mxGeometry height="47" width="837" x="2069" y="456" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-15" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=15;verticalAlign=middle;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;b&gt;举例&lt;/b&gt;：高性能Web 服务器、大型多人在线（MMO）游戏的服务端。通常的解决方案是使用&lt;span style=&quot;font-weight:bold&quot;&gt;线程本地内存池（Thread-Local&lt;br&gt;Allocation Buffer, TLAB）&lt;/span&gt;，为每个线程分配独立的池，从而彻底消除加锁开销&lt;/p&gt;" vertex="1">
          <mxGeometry height="48" width="819" x="2069" y="498" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-16" parent="1" style="shape=curlyBracket;whiteSpace=wrap;html=1;rounded=1;labelPosition=left;verticalLabelPosition=middle;align=right;verticalAlign=middle;" value="" vertex="1">
          <mxGeometry height="62.83" width="20" x="2049" y="470" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-17" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=16;verticalAlign=middle;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans&amp;quot;;&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;4.对CPU缓存命中率&lt;/span&gt;&lt;span style=&quot;font-weight: bold; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-family: Helvetica;&quot;&gt;（Cache Locality）敏感的计算&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="30.81" width="385" x="2036" y="541" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-18" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=15;verticalAlign=middle;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;痛点：&lt;/span&gt;如果使用标准分配器构建链表、树等节点型数据结构，节点在内存中的物理地址通常是随机分散的，遍历时会导致频繁的 Cache Miss，极大拖慢执行速度&lt;/p&gt;" vertex="1">
          <mxGeometry height="45" width="820" x="2069" y="568" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-19" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=15;verticalAlign=middle;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;场景举例：&lt;/span&gt; 实体组件系统（ECS）中的组件数据存储、寻路算法（如A*）中的节点评估集合。使用内存池可以确保这些节点在物理内存上是紧凑连续排列的，从而享受 CPU 硬件预取的红利&lt;/p&gt;" vertex="1">
          <mxGeometry height="48" width="809" x="2069" y="608" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-20" parent="1" style="shape=curlyBracket;whiteSpace=wrap;html=1;rounded=1;labelPosition=left;verticalLabelPosition=middle;align=right;verticalAlign=middle;" value="" vertex="1">
          <mxGeometry height="62.83" width="20" x="2049" y="580" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-29" edge="1" parent="1" source="G5onTS8pnKVt104G9YcV-21" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="G5onTS8pnKVt104G9YcV-28">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-21" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=16;verticalAlign=middle;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans&amp;quot;;&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;5.资源受限或需要严格防范OOM(Out Of Memory) 的环境&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="30.81" width="423" x="2036" y="656" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-22" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=15;verticalAlign=middle;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;痛点：&lt;/span&gt; 内存耗尽或因碎片导致无法分配出足够大的连续内存块。&lt;/p&gt;" vertex="1">
          <mxGeometry height="25" width="550" x="2072" y="681" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-24" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=15;verticalAlign=middle;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;场景举例：&lt;/span&gt;嵌入式系统、主机游戏开发。在这些环境中，内存上限是绝对固定的。通过在程序启动时划分好不同子系统（音频、渲染、AI）的内存池，可以实现严格的内存预算控制，避免一个子系统泄漏导致整个程序崩溃。&lt;/p&gt;" vertex="1">
          <mxGeometry height="46" width="815" x="2071" y="702" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-25" parent="1" style="shape=curlyBracket;whiteSpace=wrap;html=1;rounded=1;labelPosition=left;verticalLabelPosition=middle;align=right;verticalAlign=middle;" value="" vertex="1">
          <mxGeometry height="42.42" width="20" x="2052" y="693.58" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-27" parent="1" style="text;whiteSpace=wrap;html=1;fontStyle=4" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;如果你的程序主要是分配生命周期很长的大对象（如加载一张高清纹理贴图），或者内存分配频率极低，那么直接使用系统的new 或 malloc 是最明智的选择。引入内存池反而会增加代码复杂度和维护成本。&lt;/p&gt;" vertex="1">
          <mxGeometry height="64" width="956" x="2009" y="1158" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-28" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=20;fontColor=#FF0000;" value="OOM补充" vertex="1">
          <mxGeometry height="30" width="94" x="2058" y="762" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-30" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=16;verticalAlign=middle;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;当程序向操作系统申请内存，但系统已经&lt;span style=&quot;font-weight:bold&quot;&gt;没有多余的物理或虚拟内存&lt;/span&gt;可以分配给它时，就会触发 OOM 错误。一旦发生&#xa;OOM，操作系统为了自保，通常会强行杀掉（Kill）这个程序，导致程序突然崩溃、闪退，甚至可能引起整个设备的重启。&lt;/p&gt;" vertex="1">
          <mxGeometry height="53" width="889" x="2061" y="792" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-32" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=15;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;“需要严格防范OOM 的环境”并不是指某个特定的系统名称，而是指那些&lt;span style=&quot;font-weight:bold&quot;&gt;极易触发内存耗尽&lt;/span&gt;，或者&lt;span style=&quot;font-weight:bold&quot;&gt;绝对不能容忍内存崩溃&lt;/span&gt;的应用场景。&lt;/p&gt;" vertex="1">
          <mxGeometry height="45.76" width="809.95" x="2064" y="847" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-33" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=17;verticalAlign=middle;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans&amp;quot;;&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;硬件资源极其有限的环境（容易 OOM）&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="26" width="302" x="2064" y="896" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-34" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=15;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;代表场景：&lt;/span&gt; 嵌入式设备（如智能手表、IoT传感器、路由器）、早期的游戏主机、或者低端智能手机。&lt;/p&gt;" vertex="1">
          <mxGeometry height="29" width="705" x="2094" y="922" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-35" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=15;verticalAlign=middle;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;痛点：&lt;/span&gt; 内存可能只有几 MB 到几百MB。稍微大手大脚地动态申请内存，或者发生一点点内存泄漏，就会立刻把系统撑爆。&lt;/p&gt;" vertex="1">
          <mxGeometry height="25" width="816.64" x="2094" y="948" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-36" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=16;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;如果频繁使用系统自带的new 或 malloc，会导致一个隐形杀手：&lt;span style=&quot;font-weight:bold&quot;&gt;内存碎片（Memory Fragmentation）&lt;/span&gt;。&lt;/p&gt;" vertex="1">
          <mxGeometry height="33" width="772" x="2064" y="977" as="geometry" />
        </mxCell>
        <mxCell id="G5onTS8pnKVt104G9YcV-37" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=15;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;内存池的防范策略（预算制管理）：&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;使用了内存池后，程序在刚启动的时候，就会直接向操作系统“买断”一块巨大且连续的内存（例如直接申请50MB）。&lt;/p&gt;&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-weight: bold;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;启动即验证：&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; 如果启动时这 50MB&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;都申请不下来，程序干脆就不启动，尽早暴露问题。&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;span style=&quot;font-weight: bold; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;运行时安全：&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;只要启动成功了，以后程序运行过程中的所有内存需求，都在这 50MB&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;的内存池内部自己消化、自己循环利用。它从根源上杜绝了程序运行到一半向系统要内存被拒绝（OOM）的风险，同时也消除了内存碎片带来的隐患。&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="109" width="849" x="2064" y="1013" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=40;fontColor=#CC00CC;fontStyle=1" value="内存分配" vertex="1">
          <mxGeometry height="45" width="179" x="-624" y="5" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-6" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=30;" value="&lt;p style=&quot;margin: 0in;&quot;&gt;&lt;span style=&quot;font-weight:bold;font-family:&amp;quot;Google Sans&amp;quot;&quot;&gt;·通用分配器 (&lt;/span&gt;&lt;span style=&quot;font-weight:bold;font-family:&amp;quot;Google Sans Text&amp;quot;&quot;&gt;malloc&lt;/span&gt;&lt;span style=&quot;font-weight:bold;font-family:&amp;quot;Google Sans&amp;quot;&quot;&gt;)&amp;nbsp;&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 0in;&quot;&gt;&lt;span style=&quot;font-weight:bold;font-family:&amp;quot;Google Sans&amp;quot;&quot;&gt;·内存池&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="88" width="350" x="-996" y="58" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-8" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;可以把malloc 想象成一个五金店老板，而内存池是一个自动售货机&lt;/p&gt;" vertex="1">
          <mxGeometry height="38" width="600" x="-990" y="154" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-9" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=20;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;通用分配器 (malloc)：包治百病，但代价高昂&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="40" width="425" x="-986" y="192" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-10" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=20;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;span style=&quot;mso-spacerun:yes&quot;&gt;&lt;b&gt;机制&lt;/b&gt;：&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;它必须准备好应对&lt;span style=&quot;font-weight:bold&quot;&gt;任何时刻、任何大小&lt;/span&gt;的内存请求。&lt;/p&gt;&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;你可能先要8 字节，又要 1024 字节，然后释放那个 8 字节。&lt;/p&gt;&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;b&gt;缺点&lt;/b&gt;：&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-family: Helvetica;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-family: Helvetica;&quot;&gt;为了管理这些杂乱无章的内存块，它需要在底层维护复杂的数据结构（去记录哪些内存空闲、&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-family: Helvetica;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;哪些被占用、每一块有多大）。每次调用malloc，它都要去“寻找”合适的空闲块；&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-family: Helvetica;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;每次调用 free，它可能还要去“合并”相邻的空闲块。这不仅速度慢、破坏缓存局部性（Cache &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Locality），而且必定会导致&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-family: Helvetica; font-weight: bold;&quot;&gt;外部碎片&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="168" width="903" x="-948" y="225.17" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-11" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;内存池 (Pool Allocator)：极度专一，极致性能&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="35" width="445" x="-986" y="396" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-12" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;fontSize=18;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;font-weight: bold;&quot;&gt;工作机制：&lt;/span&gt;它放弃了通用性，通常只负责分配固定大小（Fixed-size）的数据结构。&lt;/font&gt;&lt;/p&gt;&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;在初始化时，它会一次性&lt;/font&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(18, 18, 18)); font-size: 20px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;向系统申请一大片连续的内存，然后像切豆腐一样，&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(18, 18, 18)); font-size: 20px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;把它切成大小完全相同的“块（Chunks）”。&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="69" width="792" x="-963" y="437" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-14" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;管理方式：&lt;/span&gt; 它只需用一个简单的单向链表（Free List）把所有空闲的块串起来。&lt;/p&gt;" vertex="1">
          <mxGeometry height="39.14" width="775.14" x="-963" y="515.5" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-16" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;绝对优势：&lt;/span&gt; * &lt;span style=&quot;font-weight:bold&quot;&gt;极速：&lt;/span&gt;分配内存就是把链表头部的第一个块拿走，释放内存就是把块重新插&lt;/p&gt;&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;回链表头部。没有复杂的查找或合并操作，时间复杂度是绝对的 $O(1)$。&lt;/p&gt;" vertex="1">
          <mxGeometry height="61" width="853" x="-963" y="557.5" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-18" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=20;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;零外部碎片：&lt;/span&gt;因为所有块的大小都一模一样，任何一个被释放的块，都能完美装&lt;/p&gt;&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;下下一个同样&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;类型的分配请求。&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="61" width="722.22" x="-850.11" y="621.5" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-19" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;缓存友好：&lt;/span&gt; 物理内存是连续的，CPU 预取数据时命中率极高。&lt;/p&gt;" vertex="1">
          <mxGeometry height="37.17" width="688.11" x="-850.11" y="678.5" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-20" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=20;fontColor=#FF0000;fontStyle=1" value="如何避免分配器产生的碎片问题" vertex="1">
          <mxGeometry height="36" width="283" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-21" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=17;verticalAlign=middle;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Microsoft YaHei&amp;quot;;&quot;&gt;碎片产生是由于多次分配和回收导致的小块不连续的内存空闲区域。可能的碎片类型：&lt;b&gt;内部碎片&lt;/b&gt;和&lt;b&gt;外部碎片&lt;/b&gt;。&lt;/p&gt;&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Microsoft YaHei&amp;quot;;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;可以考虑使用&lt;b&gt;固定大小的块&lt;/b&gt;（例如块状分配），或者&lt;b&gt;对象池机制&lt;/b&gt;来减少碎片。&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Microsoft YaHei&amp;quot;;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;同时，合理设计&lt;b&gt;对齐&lt;/b&gt;边界也可以降低碎片产生。&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Microsoft YaHei&amp;quot;;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;需要权衡内存利用率与碎片最小化之间的关系，这也是算法设计中的难点。&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="78" width="890" x="38" y="36" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-22" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Microsoft YaHei&amp;quot;;font-size:15.0pt&quot;&gt;通过采用&lt;span style=&quot;font-weight:bold&quot;&gt;固定块分配&lt;/span&gt;、&lt;span style=&quot;font-weight:bold&quot;&gt;对象池设计&lt;/span&gt;、&lt;span style=&quot;font-weight:bold&quot;&gt;&lt;u&gt;对齐策略&lt;/u&gt;&lt;/span&gt;和&lt;span style=&quot;font-weight:bold&quot;&gt;内存整理&lt;/span&gt;（如内存紧缩）等方法，能够有效减少碎片，提高内存利用率。&lt;/p&gt;" vertex="1">
          <mxGeometry height="68" width="898" x="38" y="109" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-23" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=20;fontColor=#FF0000;" value="详细解答" vertex="1">
          <mxGeometry height="38" width="82" x="3" y="170" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-24" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=18;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;内部碎片（Internal Fragmentation）：&lt;/span&gt;分配器给你的内存比你请求的要大（通常为了内存对齐或固定块大小），&lt;/p&gt;&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;多出来的这部分无法被利用。&lt;/p&gt;" vertex="1">
          <mxGeometry height="52" width="919" x="38" y="202" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-25" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=18;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;外部碎片（External Fragmentation）：&lt;/span&gt;内存中有很多空闲块，总空间加起来足够大，但它们是不连续的，&lt;/p&gt;&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans Text&amp;quot;;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;导致无法满足一次大块内存的分配请求。&lt;/p&gt;" vertex="1">
          <mxGeometry height="55" width="890" x="38" y="248" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-26" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;这两种碎片，尤其是更致命的外部碎片，底层开发中通常会采用以下几种策略来避免或缓解&lt;/p&gt;" vertex="1">
          <mxGeometry height="35" width="851" x="38" y="297" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-27" parent="1" style="text;whiteSpace=wrap;html=1;fontStyle=4" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans&amp;quot;;font-size:16.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;放弃通用分配，拥抱线性分配器（Arena / Linear Allocator）&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="41" width="588" x="3" y="343" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-29" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;在游戏循环或特定任务中，这是最高效、最能彻底消灭外部碎片的方案&lt;/p&gt;" vertex="1">
          <mxGeometry height="40.22" width="637.78" x="85" y="376" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-30" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;原理：&lt;/span&gt; 预先申请一大块连续内存，内部维护一个指针。每次分配只需将指针向前移动相应的字节数。&lt;/p&gt;" vertex="1">
          <mxGeometry height="26.83" width="895" x="85" y="413.17" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-31" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;生命周期管理：&lt;/span&gt; 不提供针对单个对象的 free()操作。而是在某一个生命周期结束时&lt;/p&gt;&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;(比如一帧结束、或者一个游戏关卡卸载时)，将指针直接重置回起点&lt;/p&gt;" vertex="1">
          <mxGeometry height="61" width="881" x="85" y="440" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-32" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;优点：&lt;/span&gt; O(1) 的分配速度，绝对没有外部碎片。非常适合每帧需要生成大量临时数据的场景&lt;/p&gt;" vertex="1">
          <mxGeometry height="36" width="806" x="85" y="496" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-33" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;fontStyle=4" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans&amp;quot;;font-size:16.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;固定大小的对象池（Pool Allocator）&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="36.33" width="360.78" x="3" y="528" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-34" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;当需要频繁创建和销毁生命周期不规则的对象（比如游戏中的粒子、怪物、子弹）时，通用&#xa;malloc 会把内存切得七零八落。对象池是解决这个问题的标准答案。&lt;/p&gt;" vertex="1">
          <mxGeometry height="50" width="888" x="85" y="564.33" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-35" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;原理：&lt;/span&gt; &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;将一大块内存划分为大小完全相同的“块（Chunk）”。&lt;/p&gt;&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;使用一个空闲链表（Free List）把未使用的块串联起来。&lt;/p&gt;&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;每次分配拿走链表头，每次释放把块插回链表头。&lt;/p&gt;" vertex="1">
          <mxGeometry height="75.5" width="837" x="85" y="618.5" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-36" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;如何避免碎片：&lt;/span&gt; 因为所有块的大小都一样，任何被释放的块都能完美容纳下一个同类型的分配&lt;/p&gt;&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;请求，从而&lt;span style=&quot;font-weight:bold&quot;&gt;彻底消除了外部碎片&lt;/span&gt;。&lt;/p&gt;" vertex="1">
          <mxGeometry height="94" width="850" x="85" y="694" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-37" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;内部碎片妥协：&lt;/span&gt;如果你把不同大小的数据塞进同一个池子，会产生内部碎片。&lt;/p&gt;&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;因此通常会为不同类型的实体创建独立的对象池。&lt;/p&gt;" vertex="1">
          <mxGeometry height="46" width="863" x="85" y="753" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-38" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;fontStyle=4" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans&amp;quot;;font-size:16.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;大小分级与隔离空闲链表（Segregated Free Lists / Slab Allocator）&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="39" width="669" y="802" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-39" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;如果你确实需要一个通用分配器（类似自己实现一个 malloc），&lt;span style=&quot;font-size: 15pt; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;可以借鉴 Doug Lea 的dlmalloc 或 jemalloc 的思路。&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="51" width="864" x="85" y="837" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-40" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;原理：&lt;/span&gt; 准备多个空闲链表，每个链表只负责特定大小范围的内存块&lt;span style=&quot;font-size: 15pt; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;(16字节、32字节、64字节...）。&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;当请求内存时，向上取整到最近的大小类别（Size Class），并从对应的链表中分配。&lt;/p&gt;" vertex="1">
          <mxGeometry height="48" width="870" x="85" y="884" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-41" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;如何避免碎片：&lt;/span&gt;它通过牺牲一小部分内部碎片（向上取整），极大地减少了外部碎片，&lt;/p&gt;&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;因为相同大小范围的内存块被集中管理了，交错分配的情况大大降低。&lt;/p&gt;" vertex="1">
          <mxGeometry height="57" width="878" x="85" y="926" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-42" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;fontStyle=4" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans&amp;quot;;font-size:16.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;伙伴系统（Buddy System）&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="37" width="273" y="983" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-43" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;原理：&lt;/span&gt; &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;内存块的大小总是 2的幂。&lt;/p&gt;&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;如果需要的内存小于当前块的一半，就把当前块一分为二，成为两个“伙伴（Buddy）”。&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;释放时，如果发现它的“伙伴”也是空闲的，就立即将它们合并（Coalescing）成一个更大的块。&lt;/p&gt;" vertex="1">
          <mxGeometry height="84" width="938" x="62" y="1009.5" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-44" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;如何避免碎片：&lt;/span&gt; 快速合并机制能有效抵抗外部碎片的累积，但代价是会产生最高达 50%&lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;的内部碎片(比如你只需要 129 字节，它会分配 256 字节给你）。&lt;/p&gt;" vertex="1">
          <mxGeometry height="54" width="905" x="62" y="1093.5" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-45" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;fontStyle=4" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans&amp;quot;;font-size:16.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;内存整理（Memory Compaction）与句柄（Handles）&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="33" width="537" x="3" y="1147" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-46" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;如果必须在内存中移动数据来“挤出”连续空间（类似磁盘碎片整理），你就不能向用户暴露原始的C 指针。&lt;/p&gt;" vertex="1">
          <mxGeometry height="27" width="957" x="38" y="1180" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-47" parent="1" style="text;whiteSpace=wrap;html=1;verticalAlign=middle;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;原理：&lt;/span&gt; 分配器返回一个句柄（通常是一个索引或ID），用户在需要访问数据时，通过句柄查表获得真实指针。&lt;/p&gt;" vertex="1">
          <mxGeometry height="30" width="960" x="36.5" y="1207" as="geometry" />
        </mxCell>
        <mxCell id="MS3efryZTIjpIkF84NTf-48" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;如何避免碎片：&lt;/span&gt;当分配器发现外部碎片严重时，它可以暂停系统，将内存中存活的对象移动到连续的&lt;/p&gt;&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;空间中，然后更新句柄表中的真实指针。&lt;/p&gt;&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;这种做法在游戏引擎的资源管理系统（如纹理、音频加载）中比较常见&lt;/p&gt;" vertex="1">
          <mxGeometry height="84" width="939" x="36" y="1241" as="geometry" />
        </mxCell>
        <mxCell id="HmgQybzJTobprx0O6-0v-3" edge="1" parent="1" style="endArrow=classic;html=1;rounded=0;shape=flexArrow;" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="407" y="146" as="sourcePoint" />
            <mxPoint x="1031" y="146" as="targetPoint" />
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="FqppAS8vuAG5zMZG88hM" name="Page-3">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="1000" pageHeight="1600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
