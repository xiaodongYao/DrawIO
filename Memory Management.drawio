        <mxCell id="qWZpPbq2GA6Z5xrev1HH-78" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontStyle=1" value="Bus" vertex="1">
