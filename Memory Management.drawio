        <mxCell id="qWZpPbq2GA6Z5xrev1HH-110" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=16;" value="CoreA 读取data，发出读请求，总线无人响应。从内存读取data，状态变为&lt;b&gt;E&lt;/b&gt;" vertex="1">
          <mxGeometry height="43" width="284" x="-1986.5" y="818" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-111" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=16;" value="CoreB 读取data，发出读请求，A嗅探到有人要共享。A 状态降级为&lt;b&gt;S&lt;/b&gt;，B读取到data，状态也为&lt;b&gt;S&lt;/b&gt;" vertex="1">
          <mxGeometry height="43" width="327" x="-1673" y="821" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-112" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=16;" value="CoreA 想要写入data，但是是S状态无法直接写。A在总线广播&quot;我要写(Invalidate)信号&quot;&lt;div&gt;B嗅探到，将自己的状态改I(Invalid)&lt;/div&gt;" vertex="1">
          <mxGeometry height="65" width="327" x="-1336.5" y="810" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-113" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=16;" value="CoreA 收到B的Invalid信号，将状态变为M(Modified)并写入新值" vertex="1">
          <mxGeometry height="65" width="283" x="-1989" y="1055.5" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-114" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=16;" value="CoreB读取数据data，发现是I(缓存未命中)，重新读取数据，发出读取请求" vertex="1">
          <mxGeometry height="65" width="283" x="-1660" y="1054.5" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-115" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=16;" value="CoreA嗅探到读请求，发现自己是M状态，必须先暂停A的读取，先把内存写回内存或直接传给B。&lt;div&gt;A降级为S，B拿到数据也为S&lt;/div&gt;" vertex="1">
          <mxGeometry height="87" width="283" x="-1327" y="1054.5" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-116" parent="1" style="text;whiteSpace=wrap;html=1;fontColor=#0000FF;fontSize=30;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans&amp;quot;;&quot;&gt;&lt;b&gt;内存屏障和C/C++ 中的volatile&lt;/b&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="51" width="444.5" x="-1988" y="1176" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-117" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=20;fontColor=#FF0000;fontStyle=1" value="内存屏障见左图示" vertex="1">
          <mxGeometry height="30" width="179" x="-1962" y="1259" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-118" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=20;fontColor=#FF0000;fontStyle=1" value="C/C++中的volatile" vertex="1">
          <mxGeometry height="30" width="181" x="-1954.5" y="1298" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-119" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=19;" value="1.告诉编译器“这个变量可能会被未知的外部因素（如硬件中断、I/O端口）修改”。" vertex="1">
          <mxGeometry height="30" width="746" x="-1915" y="1334" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-120" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;2.禁止&lt;span style=&quot;font-weight:bold&quot;&gt;编译器&lt;/span&gt;对该变量进行优化（比如不要把它缓存在寄存器里，每次都要去内存读）。&lt;/p&gt;" vertex="1">
          <mxGeometry height="46" width="804" x="-1915" y="1370" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-121" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;p style=&quot;margin:0in;font-family:&amp;quot;Google Sans Text&amp;quot;;font-size:15.0pt&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;3.不能&lt;/span&gt;阻止 CPU 硬件层面的指令重排序！&lt;/p&gt;" vertex="1">
          <mxGeometry height="46" width="377" x="-1914.99990234375" y="1417" as="geometry" />
        </mxCell>
        <mxCell id="qWZpPbq2GA6Z5xrev1HH-122" parent="1" style="text;whiteSpace=wrap;html=1;fontColor=#0000FF;fontSize=30;" value="&lt;p style=&quot;margin: 0in; font-family: &amp;quot;Google Sans&amp;quot;;&quot;&gt;&lt;b&gt;Lock-Free (无锁编程) CAS (Compare-And-Swap)&lt;/b&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="51" width="715" x="-988" y="13.5" as="geometry" />
        </mxCell>
      </root>
